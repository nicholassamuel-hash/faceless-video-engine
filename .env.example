# ---------------------------------------------------------------------------
# Faceless video engine configuration.
# Copy this file to ".env" and fill in real values. NEVER commit ".env".
# ---------------------------------------------------------------------------

# --- Paths -----------------------------------------------------------------
# Root folder where all generated assets and the SQLite DB are written.
FE_WORK_DIR=.\work
# SQLite database URL (relative paths are resolved under FE_WORK_DIR).
FE_DB_URL=sqlite:///faceless.db

# --- Language / voices -----------------------------------------------------
# Default language: "id" (Indonesian) or "en" (English). Drives default voice.
FE_LANGUAGE=id
# Edge-TTS voice ids. Override to use a different voice.
FE_VOICE_ID=id-ID-ArdiNeural
FE_VOICE_EN=en-US-AndrewNeural

# --- Video output ----------------------------------------------------------
FE_WIDTH=1080
FE_HEIGHT=1920
FE_FPS=30
# Target total duration bounds (seconds). The pipeline aims to land in range.
FE_MIN_SECONDS=30
FE_MAX_SECONDS=50

# --- Clipping (YouTube -> Shorts) ------------------------------------------
# Target/min/max length of each clip the LLM carves out of a source video.
FE_CLIP_TARGET_SECONDS=60
FE_CLIP_MIN_SECONDS=20
FE_CLIP_MAX_SECONDS=90
# How many clips to pull from one source video.
FE_CLIPS_PER_VIDEO=1
# 9:16 framing: "blur" (fit + blurred fill, keeps whole frame) or "fill"
# (center-crop, zooms in / loses sides).
FE_CLIP_CROP_MODE=blur
# Which YouTube auto-caption language to fetch ("en", "id", ...).
FE_CLIP_SUB_LANG=en

# --- LLM (script generation) ----------------------------------------------
# Provider: "openai" (OpenAI-compatible: OpenRouter/Groq/DeepSeek/OpenAI/...) or
# "template" (keyless generic fallback). "openai" needs LLM_API_KEY; without it,
# it falls back to the template generator automatically.
FE_LLM_PROVIDER=openai
# Paste your key here (e.g. an OpenRouter key: sk-or-v1-...). NEVER commit this.
LLM_API_KEY=
# OpenRouter base URL (swap for Groq/DeepSeek/OpenAI as needed):
#   OpenRouter: https://openrouter.ai/api/v1
#   Groq:       https://api.groq.com/openai/v1
#   DeepSeek:   https://api.deepseek.com
#   OpenAI:     https://api.openai.com/v1
FE_LLM_BASE_URL=https://openrouter.ai/api/v1
# Model slug for the chosen provider. OpenRouter examples:
#   openai/gpt-4o-mini  (cheap, solid)   |  anthropic/claude-3.5-sonnet (best)
#   google/gemini-2.0-flash-001          |  meta-llama/llama-3.3-70b-instruct
FE_LLM_MODEL=openai/gpt-4o-mini

# --- Imagery ---------------------------------------------------------------
# Provider:
#   "openverse"   keyless real CC photos (free, hit-or-miss relevance)
#   "openrouter"  AI image generation via your LLM_API_KEY (~$0.04/image,
#                 always relevant, beautiful) <-- best quality
#   "http"        your own AI image API via IMAGE_API_KEY (TODO stub)
#   "placeholder" ffmpeg gradients (fast smoke tests)
FE_IMAGE_PROVIDER=openverse
# OpenRouter image model (when FE_IMAGE_PROVIDER=openrouter). Options:
#   google/gemini-2.5-flash-image  (~$0.04/img, great)
#   google/gemini-3-pro-image-preview / openai/gpt-5-image (pricier)
FE_IMAGE_OR_MODEL=google/gemini-2.5-flash-image
# Only needed when FE_IMAGE_PROVIDER=http (request is a TODO stub in imagery.py).
IMAGE_API_KEY=
FE_IMAGE_API_URL=https://api.example-image-gen.com/v1/images
FE_IMAGE_MODEL=default

# --- Uploader: safety ------------------------------------------------------
# SAFE defaults. Flip these to go live (you have to do it on purpose).
#   TikTok mode:  "draft"  -> upload to inbox (safe)   | "direct" -> auto-post
#   YouTube mode: "private" (safe) | "public" | "unlisted"
FE_TIKTOK_MODE=draft
FE_YOUTUBE_PRIVACY=private

# --- Uploader: scheduling --------------------------------------------------
# Randomized jitter (minutes) slept BEFORE each upload, and BETWEEN uploads.
FE_JITTER_MIN_MINUTES=8
FE_JITTER_MAX_MINUTES=45
# Per-platform max uploads per calendar day.
FE_TIKTOK_MAX_PER_DAY=3
FE_YOUTUBE_MAX_PER_DAY=5

# --- TikTok Content Posting API -------------------------------------------
# https://developers.tiktok.com/doc/content-posting-api-get-started
TIKTOK_ACCESS_TOKEN=

# --- YouTube Data API v3 ---------------------------------------------------
# Path to your OAuth client-secrets JSON (Desktop app credentials).
YOUTUBE_CLIENT_SECRETS=.\secrets\youtube_client_secret.json
# Where the cached OAuth token is stored after first run.
YOUTUBE_TOKEN_FILE=.\secrets\youtube_token.json
