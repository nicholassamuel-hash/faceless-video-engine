# =============================================================
#  Copy this file to ".env" and fill in the values.
#  cp .env.example .env
#  NEVER commit the real .env (it is git-ignored).
# =============================================================

# ── General ──────────────────────────────────────────────────
# Use a valid TZ name, e.g. Europe/London, America/New_York, Etc/UTC
TIMEZONE=Etc/UTC

# ── Server (Phase 1) ─────────────────────────────────────────
# Your VPS public IP address, e.g. 203.0.113.5
VPS_IP=YOUR_SERVER_IP

# ── n8n (Phase 1) ────────────────────────────────────────────
# 32+ char random string. Generate with: openssl rand -hex 24
# Once set, DO NOT change it or saved credentials become unreadable.
N8N_ENCRYPTION_KEY=replace-with-openssl-rand-hex-24

# ── Flowise (Phase 1) ────────────────────────────────────────
FLOWISE_USERNAME=admin
FLOWISE_PASSWORD=replace-with-a-strong-password

# ── LLM provider (Phase 2) — OpenAI-compatible, pick ONE ─────
# The workflow only reads LLM_API_BASE / LLM_API_KEY / LLM_MODEL,
# so you can switch provider by editing these three lines only.
#
# Option A — Groq (fastest, free):   https://console.groq.com/keys
#   LLM_API_BASE=https://api.groq.com/openai/v1
#   LLM_MODEL=llama-3.3-70b-versatile
#
# Option B — OpenRouter (flexible):  https://openrouter.ai/keys
#   LLM_API_BASE=https://openrouter.ai/api/v1
#   LLM_MODEL=meta-llama/llama-3.3-70b-instruct        (or ...:free)
#
LLM_API_BASE=https://openrouter.ai/api/v1
LLM_API_KEY=
LLM_MODEL=meta-llama/llama-3.3-70b-instruct
# Optional, OpenRouter-only attribution (ignored by Groq):
LLM_APP_URL=http://localhost
LLM_APP_NAME=Cart Recovery Bot

# ── SMTP email provider (Phase 2) — pick ONE ─────────────────
# The workflow only reads SMTP_HOST / SMTP_PORT / SMTP_USER /
# SMTP_PASS / SMTP_FROM_EMAIL / SMTP_FROM_NAME, so switching
# provider is an .env-only change. Port 587 = STARTTLS (recommended).
#
# Option A — Gmail (free, no domain, ~500/day):
#   Needs 2-Step Verification ON, then an "App Password".
#   SMTP_HOST=smtp.gmail.com   SMTP_PORT=587
#   SMTP_USER=you@gmail.com    SMTP_PASS=<16-char app password>
#   SMTP_FROM_EMAIL=you@gmail.com
#
# Option B — SMTP2GO (free 1k/mo, no domain to start):
#   SMTP_HOST=mail.smtp2go.com SMTP_PORT=587
#
# Option C — Brevo TRANSACTIONAL relay (only if not blocked):
#   SMTP_HOST=smtp-relay.brevo.com SMTP_PORT=587
#
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_EMAIL=
SMTP_FROM_NAME=Your Store

# ── Meta WhatsApp Cloud API (Phase 2 — optional stretch) ─────
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# =============================================================
#  OPTIONAL — upgrade to real HTTPS (free, ~2 min, green lock)
#  -----------------------------------------------------------
#  No domain needed: nip.io maps any hostname to your IP with
#  zero signup. Keep the dots in your IP — e.g. for 203.0.113.5:
#     DEMO_HOST=app.203.0.113.5.nip.io
#     N8N_HOST=n8n.203.0.113.5.nip.io
#     FLOWISE_HOST=flowise.203.0.113.5.nip.io
#  (DuckDNS is a more rate-limit-proof alternative — see DEPLOY.md)
#
#  Then launch with the HTTPS overlay (and open port 443!):
#     docker compose -f docker-compose.yml -f docker-compose.https.yml up -d
#  Caddy fetches real Let's Encrypt certs automatically.
# =============================================================
DEMO_HOST=
N8N_HOST=
FLOWISE_HOST=
ACME_EMAIL=
